# ============================
# FoodBridge AI — Environment Variables
# ============================
# Copy this file to .env and fill in values:
#   cp .env.example .env

# --- PostgreSQL Database ---
# Connection URL for the PostgreSQL database
POSTGRES_USER=foodbridge
POSTGRES_PASSWORD=foodbridge_secret_2024
POSTGRES_DB=foodbridge
DATABASE_URL=postgresql://foodbridge:foodbridge_secret_2024@postgres:5432/foodbridge

# --- Redis ---
# Connection URL for Redis (pub/sub + distributed locks + token store)
REDIS_URL=redis://redis:6379/0

# --- JWT Authentication ---
# Secret key for signing JWT tokens (replace with a strong random string)
JWT_SECRET=replace_with_a_strong_32_char_secret_key_here
# Algorithm for JWT encoding
JWT_ALGORITHM=HS256
# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiry in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OSRM Routing (Optional) ---
# URL of the OSRM routing server. Leave blank to use fallback speed estimation (30 km/h)
OSRM_URL=

# --- Service URLs (internal Docker network) ---
# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000
# AI Engine internal URL
AI_ENGINE_URL=http://ai_engine:8001
# Backend URL (used by frontend)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
